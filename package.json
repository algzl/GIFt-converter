{
  "name": "gift-converter",
  "version": "0.1.0",
  "productName": "gift-converter",
  "description": "Desktop bulk video to GIF converter app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win portable"
  },
  "keywords": [
    "electron",
    "gif",
    "video",
    "converter"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "co.ycswu.giftconverter",
    "productName": "gift-converter",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json",
      "package-lock.json"
    ],
    "directories": {
      "output": "release"
    },
    "artifactName": "gift-converter-${version}.${ext}",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "ffmpeg-static": "^5.2.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  }
}
